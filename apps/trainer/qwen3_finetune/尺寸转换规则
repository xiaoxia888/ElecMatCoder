    size_obj,amb=extract_size_struct(out.get('SIZE'),inp,idx)
    if size_obj:
        new_out['SIZE']=size_obj
        for k,vals in size_obj.items():
            if vals:
                size_subcounts[k]+=1
    if amb:
        ambiguous_cases.append({'index':idx,'input':inp,'original_size':flatten_strings(out.get('SIZE')),'converted_size':size_obj,'ambiguous_items':amb})
    th=normalize_thickness(out.get('THICKNESS'))
    if th:
        new_out['THICKNESS']=th
    for f in ['PRESSURE','MATERIAL','STANDARD','STANDARD_GRADE','STANDARD_APPENDIX','STANDARD_METHOD']:
        val=out.get(f)
        if val in (None,'',[]):
            continue
        if isinstance(val,list):
            val=uniq(val)
            if len(val)==1 and not isinstance(val[0],dict):
                val=val[0]
        new_out[f]=val
    for k in new_out:
        field_counts[k]+=1
    new_rows.append({'input':inp,'output':new_out})

