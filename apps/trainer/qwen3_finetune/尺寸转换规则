def uniq(seq):
    out, seen = [], set()
    for x in seq:
        key = json.dumps(x, ensure_ascii=False, sort_keys=True) if isinstance(x, (dict, list)) else str(x)
        if key not in seen:
            seen.add(key)
            out.append(x)
    return out


def flatten_strings(val):
    vals = []
    if val in (None, '', []):
        return vals
    if isinstance(val, list):
        for x in val:
            if isinstance(x, dict):
                y = x.get('value', '')
                if isinstance(y, str) and y.strip():
                    vals.append(y.strip())
            elif isinstance(x, str) and x.strip():
                vals.append(x.strip())
    elif isinstance(val, dict):
        y = val.get('value', '')
        if isinstance(y, str) and y.strip():
            vals.append(y.strip())
    elif isinstance(val, str) and val.strip():
        vals.append(val.strip())
    return vals


def has_exact_token(text: str, token: str) -> bool:
    text_tokens = [t for t in re.split(r'[^A-Za-z0-9õĖĆ-ķŠź\-\./"]+', text) if t]
    token_tokens = [t for t in re.split(r'[^A-Za-z0-9õĖĆ-ķŠź\-\./"]+', token) if t]
    if not token_tokens:
        return False
    if len(token_tokens) == 1:
        return any(t.lower() == token_tokens[0].lower() for t in text_tokens)
    return token.lower() in text.lower()


def normalize_type_value(base_type, out):
    parts = []
    if isinstance(base_type, str) and base_type.strip():
        parts.append(base_type.strip())
    for f in MERGE_TO_TYPE_FIELDS:
        for v in flatten_strings(out.get(f)):
            if not v:
                continue
            if any(v.lower() == p.lower() for p in parts):
                continue
            if parts and has_exact_token(parts[0], v):
                continue
            parts.append(v)
    return ';'.join(uniq(parts)) if parts else None


def normalize_size_fragment(s: str) -> str:
    return re.sub(
        r'\s+',
        ' ',
        s.strip()
        .replace('├Ś', 'x')
        .replace('X', 'x')
        .replace('ąż', 'Žå')
        .replace('╬”', 'Žå')
        .replace('├ś', 'Žå'),
    ).strip()


def normalize_dn_num(num: str) -> str:
    return f'DN{num.strip()}'


def normalize_dn(token: str) -> str:
    m = re.search(r'DN\s*(\d+(?:\.\d+)?)', token, re.I)
    if m:
        return normalize_dn_num(m.group(1))
    m = re.fullmatch(r'[DdNn]\s*(\d+(?:\.\d+)?)', token)
    if m:
        return normalize_dn_num(m.group(1))
    return token.strip().replace(' ', '')


def normalize_inch_num(num: str) -> str:
    num = num.strip().replace(' ', '')
    return num if num.endswith('"') else num + '"'


def normalize_nps(token: str) -> str:
    m = re.search(r'NPS\s*([0-9]+(?:\.[0-9]+)?(?:-[0-9]+/[0-9]+|\s+[0-9]+/[0-9]+|/[0-9]+)?)', token, re.I)
    return normalize_inch_num(m.group(1) if m else token)


def normalize_inch(token: str) -> str:
    t = token.strip().replace(' ', '')
    return t if t.endswith('"') else t + '"'


def normalize_od(token: str) -> str:
    t = (
        token.strip()
        .replace(' ', '')
        .replace('ąż', 'Žå')
        .replace('╬”', 'Žå')
        .replace('├ś', 'Žå')
    )
    m = re.search(r'Õż¢ÕŠä\s*(\d+(?:\.\d+)?)\s*mm?', token, re.I)
    if m:
        return m.group(1)
    m = re.search(r'\bOD[:=]?\s*(\d+(?:\.\d+)?)', token, re.I)
    if m:
        return m.group(1)
    m = re.search(r'(\d+(?:\.\d+)?)\s*mm\b', token, re.I)
    if m:
        return m.group(1)
    m = re.search(r'Žå\s*(\d+(?:\.\d+)?)', t, re.I)
    if m:
        return m.group(1)
    m = re.search(r'\bOD[:=]?\s*(\d+(?:\.\d+)?)', t, re.I)
    if m:
        return m.group(1)
    return t


def is_fraction_like_inch(s: str) -> bool:
    return bool(re.fullmatch(r'(?:\d+\s+\d+/\d+|\d+-\d+/\d+|\d+/\d+)', s))


def is_decimal_or_int(s: str) -> bool:
    return bool(re.fullmatch(r'\d+(?:\.\d+)?', s))


def parse_numeric_compound(s: str):
    if re.fullmatch(r'\d+(?:\.\d+)?(?:x\d+(?:\.\d+)?)+', s):
        return [p for p in s.split('x') if p]
    return None


def parse_od_compound(s: str):
    if re.fullmatch(r'[Žå]?\d+(?:\.\d+)?(?:x[Žå]?\d+(?:\.\d+)?)+', s, re.I):
        return [normalize_od(part) for part in s.split('x') if part]
    return None


def parse_od_compound_with_thickness(s: str):
    if '/' not in s:
        return None
    left, right = [part.strip() for part in s.split('/', 1)]
    left_parts = [part.strip() for part in left.split('x') if part.strip()]
    right_parts = [part.strip() for part in right.split('x') if part.strip()]
    if len(left_parts) < 2 or len(left_parts) != len(right_parts):
        return None
    if not any(re.match(r'^[Žå]', part, re.I) for part in left_parts):
        return None
    if not all(re.fullmatch(r'[Žå]?\d+(?:\.\d+)?', part, re.I) for part in left_parts):
        return None
    if not all(re.fullmatch(r'\d+(?:\.\d+)?(?:mm)?', part, re.I) for part in right_parts):
        return None
    return [normalize_od(part) for part in left_parts]


def all_known_dn(parts):
    return all(re.fullmatch(r'\d+', p) and p in KNOWN_DN for p in parts)


def extract_size_struct(size_val, input_text, idx):
    raw_vals = flatten_strings(size_val)
    if not raw_vals:
        return None, []

    dn, od, inch = [], [], []
    ambiguous = []
    has_explicit_dn_anywhere = any(re.search(r'\bDN\s*\d', normalize_size_fragment(v), re.I) for v in raw_vals) or bool(re.search(r'\bDN\s*\d', input_text, re.I))
    normalized_input = (
        input_text.replace('├Ś', 'x')
        .replace('X', 'x')
        .replace('*', 'x')
        .replace('ąż', 'Žå')
        .replace('╬”', 'Žå')
        .replace('├ś', 'Žå')
    )

    for raw in raw_vals:
        s = normalize_size_fragment(raw)
        matched = False

        pair_matches = re.findall(r'\bDN\s*(\d+(?:\.\d+)?)\s*[x/’╝ī,]\s*(?:DN\s*)?(\d+(?:\.\d+)?)', s, re.I)
        if pair_matches:
            for a, b in pair_matches:
                dn.extend([normalize_dn_num(a), normalize_dn_num(b)])
            matched = True
        single_dn = list(re.finditer(r'\bDN\s*\d+(?:\.\d+)?', s, re.I))
        if single_dn:
            for m in single_dn:
                dn.append(normalize_dn(m.group()))
            matched = True
        if re.fullmatch(r'[DdNn]\d+(?:\.\d+)?', s):
            dn.append(normalize_dn(s))
            matched = True

        explicit_nps = list(re.finditer(r'\bNPS\s*[0-9]+(?:\.[0-9]+)?(?:-[0-9]+/[0-9]+|\s+[0-9]+/[0-9]+|/[0-9]+)?', s, re.I))
        if explicit_nps:
            for m in explicit_nps:
                inch.append(normalize_nps(m.group()))
            matched = True
        explicit_quote = list(re.finditer(r'\b(?:\d+\s+\d+/\d+|\d+-\d+/\d+|\d+/\d+|\d+(?:\.\d+)?)"', s))
        if explicit_quote:
            for m in explicit_quote:
                inch.append(normalize_inch(m.group()))
            matched = True
        if is_fraction_like_inch(s):
            inch.append(normalize_inch(s))
            matched = True
        if '"' in s and re.fullmatch(r'[0-9./"x\- ]+', s):
            parts = [p.strip() for p in s.split('x') if p.strip()]
            ok = True
            parsed = []
            for part in parts:
                if re.fullmatch(r'(?:\d+\s+\d+/\d+|\d+-\d+/\d+|\d+/\d+|\d+(?:\.\d+)?)"?', part):
                    parsed.append(normalize_inch(part))
                else:
                    ok = False
                    break
            if ok and parsed:
                inch.extend(parsed)
                matched = True

        od_with_thickness = parse_od_compound_with_thickness(s)
        if od_with_thickness:
            od.extend(od_with_thickness)
            matched = True

        od_compound = parse_od_compound(s)
        if od_compound:
            od.extend(od_compound)
            matched = True

        explicit_od = list(re.finditer(r'[Žå╬”├śąż]\s*\d+(?:\.\d+)?|Õż¢ÕŠä\s*\d+(?:\.\d+)?\s*mm?|\bOD[:=]?\s*\d+(?:\.\d+)?|\b\d+(?:\.\d+)?\s*mm\b', s, re.I))
        if explicit_od:
            for m in explicit_od:
                od.append(normalize_od(m.group()))
            matched = True

        compound = parse_numeric_compound(s)
        if compound:
            if any('.' in p for p in compound):
                od.extend(compound)
            elif all_known_dn(compound) and has_explicit_dn_anywhere:
                dn.extend([normalize_dn_num(p) for p in compound])
            else:
                od.extend(compound)
            matched = True

        if not matched and is_decimal_or_int(s):
            same = re.escape(s)
            if re.search(rf'(Õż¢ÕŠä\s*{same}|[Žå╬”├śąż]\s*{same}|\b{same}\s*mm\b)', normalized_input, re.I):
                od.append(s)
            elif re.search(rf'{same}\s*[x]\s*\d+(?:\.\d+)', normalized_input):
                od.append(s)
            elif re.search(rf'{same}\s*[,’╝ī]\s*\d+(?:\.\d+)', normalized_input):
                od.append(s)
            elif '.' in s:
                od.append(s)
            elif s in KNOWN_DN:
                dn.append(normalize_dn_num(s))
            else:
                ambiguous.append({'raw_value': raw, 'reason': 'ĶŻĖµĢ┤µĢ░Õ░║Õ»ĖµŚĀµ│Ģń©│Õ«ÜÕłżµ¢Łµś» DNŃĆüĶŗ▒ÕłČĶ┐śµś»Õ×ŗÕÅĘµĢ░ÕŁŚ'})
            matched = True

        if not matched:
            ambiguous.append({'raw_value': raw, 'reason': 'µŚĀµ│ĢÕĮÆń▒╗Õł░ DN / OD / INCH’╝īĶ»Ęõ║║ÕĘźÕłżµ¢Ł'})

    dn = uniq(dn)
    od = uniq(od)
    inch = uniq(inch)
    if dn:
        od = [x for x in od if x not in {d[2:] for d in dn}]
    size_obj = None
    if dn or od or inch:
        size_obj = {}
        if dn:
            size_obj['DN'] = dn
        if od:
            size_obj['OD'] = od
        if inch:
            size_obj['INCH'] = inch
    return size_obj, ambiguous


def normalize_thickness(field_val):
    if field_val in (None, '', []):
        return None
    if isinstance(field_val, str):
        return field_val.strip()
    vals = uniq([v for v in flatten_strings(field_val) if v])
    if not vals:
        return None
    return vals[0] if len(vals) == 1 else 'x'.join(vals)

